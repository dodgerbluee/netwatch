# ============================================================
# netwatch boot-time config (optional)
#
# All service configuration (UniFi, MQTT, OPNsense, etc.) is
# managed through the web UI at Settings after first login.
#
# These env vars only control how the HTTP server starts.
# In most cases the defaults are fine and no .env file is needed.
# ============================================================

# NETWATCH_LOG_LEVEL=INFO
# NETWATCH_HTTP_HOST=0.0.0.0
# NETWATCH_HTTP_PORT=8099
# NETWATCH_DATA_DIR=/data
