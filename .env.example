# ============================================================
# netwatch local config — copy to `.env` and fill in.
# Compose loads .env automatically.
# ============================================================

# --- service ---
NETWATCH_LOG_LEVEL=INFO
NETWATCH_HTTP_HOST=0.0.0.0
NETWATCH_HTTP_PORT=8099
# Auto-block unknown devices? Set to false during initial bootstrap so
# nothing gets blocked while you populate the known-devices list.
NETWATCH_ENFORCEMENT_ENABLED=false

# --- UniFi controller (UniFi OS: UDM/UDR/UCG/Dream Router/CK2+) ---
NETWATCH_UNIFI_HOST=https://192.168.1.1
NETWATCH_UNIFI_SITE=default
NETWATCH_UNIFI_USERNAME=ha-netwatch
NETWATCH_UNIFI_PASSWORD=changeme
NETWATCH_UNIFI_VERIFY_TLS=false

# --- MQTT broker (Mosquitto add-on in Home Assistant) ---
NETWATCH_MQTT_HOST=homeassistant.local
NETWATCH_MQTT_PORT=1883
NETWATCH_MQTT_USERNAME=netwatch
NETWATCH_MQTT_PASSWORD=changeme
NETWATCH_MQTT_DISCOVERY_PREFIX=homeassistant
NETWATCH_MQTT_BASE_TOPIC=netwatch

# --- OPNsense (phase 2; leave blank to disable) ---
NETWATCH_OPNSENSE_HOST=
NETWATCH_OPNSENSE_API_KEY=
NETWATCH_OPNSENSE_API_SECRET=
